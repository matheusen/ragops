APP_NAME=Jira Issue Validation RAG
APP_ENV=dev
API_PREFIX=/api/v1
CONFIDENTIALITY_MODE=true
ALLOW_THIRD_PARTY_LLM=false
ALLOW_THIRD_PARTY_EMBEDDINGS=false
ALLOW_EXTERNAL_VECTOR_STORE=false
DEFAULT_PROVIDER=mock
SECONDARY_PROVIDER=gemini
ENABLE_SECOND_OPINION=true
ENABLE_LANGGRAPH=true
ENABLE_RERANKER=true
ENABLE_EXTERNAL_RETRIEVAL=true
PRIMARY_MODEL=mock-judge-v1
OPENAI_MODEL=gpt-5-mini
GEMINI_MODEL=gemini-2.5-flash
OPENAI_EMBEDDING_MODEL=text-embedding-3-large
GEMINI_EMBEDDING_MODEL=gemini-embedding-001
EMBEDDING_DIMENSION=64
GCP_PROJECT_ID=
GCP_LOCATION=us-central1
GOOGLE_APPLICATION_CREDENTIALS=
OPENAI_API_KEY=
GEMINI_API_KEY=
JIRA_BASE_URL=
JIRA_USER_EMAIL=
JIRA_API_TOKEN=
JIRA_PROJECT_KEY=
JIRA_VERIFY_SSL=true
STAGING_DIR=data/staging
QDRANT_URL=
QDRANT_COLLECTION=issue_evidence
QDRANT_API_KEY=
AUDIT_DIR=data/audit
EVAL_REPORTS_DIR=data/eval_reports
GOLDEN_DATASET_PATH=examples/golden_dataset.json
