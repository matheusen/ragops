APP_NAME=Jira Issue Validation RAG
APP_ENV=dev
API_PREFIX=/api/v1
CONFIDENTIALITY_MODE=true
ALLOW_THIRD_PARTY_LLM=false
ALLOW_THIRD_PARTY_EMBEDDINGS=false
ALLOW_EXTERNAL_VECTOR_STORE=false
DEFAULT_PROVIDER=mock
SECONDARY_PROVIDER=gemini
ENABLE_SECOND_OPINION=true
ENABLE_LANGGRAPH=true
ENABLE_RERANKER=true
ENABLE_EXTERNAL_RETRIEVAL=true
# Distiller: "simple" (rule-based, zero LLM cost) or "refrag" (REFRAG-style LLM compression)
DISTILLER_MODE=simple
# Provider for the REFRAG compression LLM — leave empty to reuse DEFAULT_PROVIDER.
# Use a cheaper/faster model to keep latency low (e.g. gpt-5-nano, gemini-2.5-flash-lite).
DISTILLER_PROVIDER=
# PDFs no upload/validation: use pypdf first; enable Docling only if you need richer parsing.
# In Windows, keeping Docling disabled avoids some RapidOCR/Docling crashes on problematic PDFs.
ENABLE_DOCLING_PDF_PARSER=false
ENABLE_TESSERACT_PDF_OCR=true
PRIMARY_MODEL=mock-judge-v1
OPENAI_MODEL=gpt-5-mini
GEMINI_MODEL=gemini-2.5-flash
OPENAI_EMBEDDING_MODEL=text-embedding-3-large
GEMINI_EMBEDDING_MODEL=gemini-embedding-001
EMBEDDING_DIMENSION=64
GCP_PROJECT_ID=
GCP_LOCATION=us-central1
GOOGLE_APPLICATION_CREDENTIALS=
OPENAI_API_KEY=
GEMINI_API_KEY=
JIRA_BASE_URL=
JIRA_USER_EMAIL=
JIRA_API_TOKEN=
JIRA_PROJECT_KEY=
JIRA_VERIFY_SSL=true
STAGING_DIR=data/staging
QDRANT_URL=
QDRANT_COLLECTION=issue_evidence
QDRANT_API_KEY=
REQUIRE_QDRANT_API_KEY_FOR_REMOTE=true
ALLOW_INSECURE_REMOTE_QDRANT=false
# Quantization: none | scalar | binary  (scalar=int8 economiza ~75% VRAM, binary=extremo)
QDRANT_QUANTIZATION_TYPE=none
QDRANT_QUANTIZATION_RESCORE=true
# Cascade retrieval — busca N*factor candidatos, re-ranqueia e retorna top-N
QDRANT_CASCADE_OVERRETRIEVE_FACTOR=4
ENABLE_CASCADE_RETRIEVAL=false
STRICT_ARTICLE_TENANT_ISOLATION=false
MULTI_TENANT_ARTICLE_COLLECTIONS=

# ── Neo4j GraphRAG ──────────────────────────────────────────────────────────
# Ativar: ENABLE_GRAPHRAG=true + NEO4J_URL=bolt://localhost:7687
# Docker: docker compose up neo4j -d  (ver docker-compose.yml)
ENABLE_GRAPHRAG=false
NEO4J_URL=
NEO4J_USER=neo4j
NEO4J_PASSWORD=
NEO4J_DATABASE=neo4j

# ── Ollama — provider LLM 100% local ────────────────────────────────────────
# Ativar: DEFAULT_PROVIDER=ollama
# Docker: docker compose up ollama -d
# Baixar modelo: docker exec -it ragops-ollama ollama pull llama3.1:8b
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.1:8b

# ── MonkeyOCR v1.5 — extração de PDFs complexos (SRR paradigm) ──────────────
# Requer GPU NVIDIA. Docker: docker compose --profile gpu up monkeyocr -d
# Sem GPU: deixe vazio; o sistema usa Docling → pypdf → Tesseract como fallback
MONKEYOCR_API_URL=http://localhost:8001

# ── Auto-melhoria contínua ──────────────────────────────────────────────────
AUTO_IMPROVEMENT_THRESHOLD=0.75

AUDIT_DIR=data/audit
EVAL_REPORTS_DIR=data/eval_reports
GOLDEN_DATASET_PATH=examples/golden_dataset.json
